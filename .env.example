# Copy to .env.local for local dev. On Vercel, add these under
# Project Settings -> Environment Variables.
#
# The site runs fine with NONE of these set — the portfolio renders and the
# agent page shows an empty state. Add them as you go.

# --- Job agent: scoring -------------------------------------------------
# https://console.anthropic.com -> API keys
ANTHROPIC_API_KEY=

# --- Job agent: storage -------------------------------------------------
# Neon (free tier): https://neon.tech -> create project -> copy the
# "Pooled connection" string. Looks like:
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Cron protection ----------------------------------------------------
# Any long random string. Vercel sends it as `Authorization: Bearer <this>`
# on scheduled runs. Generate one with:  openssl rand -hex 32
CRON_SECRET=

# --- Daily digest email (optional) --------------------------------------
# https://resend.com -> API keys. Verify your domain there first so mail
# from your own address doesn't land in spam.
RESEND_API_KEY=
DIGEST_FROM=agent@zackhaynie.com
DIGEST_TO=zack@zackhaynie.com
